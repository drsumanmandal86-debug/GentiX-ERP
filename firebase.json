{
  "hosting": {
    "site": "mini-erp-gentix",
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**", "firestore.rules"],
    "rewrites": [
      { "source": "/", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
